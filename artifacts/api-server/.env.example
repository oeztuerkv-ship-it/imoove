# Session-JWT nach Google-OAuth (HS256). Pflicht für /auth/google/start.
# openssl rand -base64 48
# AUTH_JWT_SECRET=
# Optional, default onroda-api
# AUTH_JWT_ISSUER=onroda-api

# Nach OAuth: Browser landet auf /auth/google/done?token=… → Redirect hierhin (Web-App).
# OAUTH_SUCCESS_WEB_URL=https://onroda.de/app

# Google OAuth (Web-Client + Secret empfohlen)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Öffentliche API-Origin ohne /api (Redirect-URI-Berechnung)
# OAUTH_PUBLIC_ORIGIN=https://api.example.com

# Firebase Admin (genau eine Variante)
# Pfad zur heruntergeladenen Service-Account-JSON (nicht ins Git legen)
# GOOGLE_APPLICATION_CREDENTIALS=/pfad/zur/onroda-firebase-adminsdk-….json

# Oder: komplettes JSON als eine Zeile (Docker Secrets / Hosting; Vorsicht bei Shell-Escaping)
# FIREBASE_SERVICE_ACCOUNT=
