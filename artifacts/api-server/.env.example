# HTTP-Port der API (verbindlich ein Port pro Instanz; Produktion + Nginx-Upstream: 3000).
# PORT=3000

# Optional: PostgreSQL — wenn gesetzt, nutzen rides + Admin-Endpunkte die DB (sonst In-Memory).
# Schema: siehe src/db/init-onroda.sql
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/onroda

# Session-JWT nach Google-OAuth (HS256). Pflicht für /auth/google/start.
# openssl rand -base64 48
# AUTH_JWT_SECRET=

# Panel-Passwort-Login (HS256, eigene Claims `kind: panel`). Eigenes Secret (nicht mit Mobile-OAuth-JWT mischen).
# Produktion: PANEL_JWT_SECRET ist Pflicht für POST /api/panel-auth/login.
# Lokal: alternativ nur AUTH_JWT_SECRET (nur NODE_ENV != production).
# PANEL_JWT_SECRET=
# PANEL_JWT_ISSUER=onroda-panel
# Optional, default onroda-api
# AUTH_JWT_ISSUER=onroda-api

# Optional: Nur wenn ihr später eine Web-Oberfläche mit Google-Login habt (z. B. panel.onroda.de).
# Ohne diese Variable: /auth/google/done zeigt einen Hinweis; Mobile bekommt das Token über returnUrl.
# NICHT die Marketing-Homepage (onroda.de) verwenden.
# OAUTH_SUCCESS_WEB_URL=https://admin.onroda.de/partners/

# Partner-/Admin-Web: Default-returnUrl für GET /api/auth/panel-login (JSON wie /auth/google/start)
# PANEL_OAUTH_RETURN_URL=https://panel.onroda.de/

# Zusätzliche erlaubte Hosts für ?returnUrl= bei panel-login (Komma-getrennt, mit oder ohne https://)
# PANEL_ALLOWED_RETURN_ORIGINS=

# Superadmin-JSON-API (`GET/PATCH /admin/*`): `Authorization: Bearer <dieser Wert>`.
# Produktion: setzen, sonst antworten /admin/* mit 503.
# openssl rand -base64 32
# ADMIN_API_BEARER_TOKEN=

# Admin-Panel Login (Web-Formular) — dauerhaft DB-basiert über table admin_auth_users.
# Diese Werte sind nur Bootstrap/Recovery: beim ersten erfolgreichen Login wird ein gehashter
# DB-User angelegt; danach ist die DB Source of Truth.
# Hinweis: keine Secrets ins Git committen, nur in Server-.env setzen.
# ADMIN_PANEL_JWT_SECRET=
# ADMIN_PANEL_USERNAME=
# ADMIN_PANEL_PASSWORD=
# Optional eingeschränkter Mitarbeiter-Zugang (kein Tarif-Edit):
# ADMIN_PANEL_SERVICE_USERNAME=
# ADMIN_PANEL_SERVICE_PASSWORD=

# Zusätzliche CORS-Origins (Komma-getrennt), z. B. Staging-URLs. Immer admin/panel/api.onroda.de sind fest eingetragen.
# CORS_ORIGINS=

# Google OAuth (Web-Client + Secret empfohlen)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Öffentliche API-Origin ohne /api (Redirect-URI-Berechnung)
# OAUTH_PUBLIC_ORIGIN=https://api.example.com

# Optional: Pfade für statische Dateien (wenn Working Directory nicht api-server ist)
# Standard: ../static relativ zu dist/index.mjs (onroda-brand.css, Marketing-index.html)
# STATIC_ROOT=/app/static
# Gebautes Admin-Panel (Vite: Repo-Root `pnpm --filter admin-panel run build` → dist/)
# Standard: ../../admin-panel/dist relativ zu api-server/dist/index.mjs
# ADMIN_STATIC_ROOT=/app/imoove/artifacts/admin-panel/dist

# Gebautes Partner-Panel (Vite: Repo-Root `pnpm --filter partner-panel run build` → dist/), Auslieferung Host panel.onroda.de
# Standard: ../../partner-panel/dist relativ zu api-server/dist/index.mjs
# PANEL_STATIC_ROOT=/app/imoove/artifacts/partner-panel/dist

# Firebase Admin (genau eine Variante)
# Pfad zur heruntergeladenen Service-Account-JSON (nicht ins Git legen)
# GOOGLE_APPLICATION_CREDENTIALS=/pfad/zur/onroda-firebase-adminsdk-….json

# Oder: komplettes JSON als eine Zeile (Docker Secrets / Hosting; Vorsicht bei Shell-Escaping)
# FIREBASE_SERVICE_ACCOUNT=
