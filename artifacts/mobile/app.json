{
  "expo": {
    "name": "Onroda",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vedat.mobile",
      "config": {
        "googleMapsApiKey": "AIzaSyC6-pFE0kCcB-57r2ALZ81SAXys8_PpeoQ"
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.584139886361-scvjrt3atv70t5r8n6m7isom08u5p2ia"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.vedat.Onroda",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyC6-pFE0kCcB-57r2ALZ81SAXys8_PpeoQ"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
