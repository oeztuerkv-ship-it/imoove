# Kopie nach scripts/onroda-deploy.env (nicht committen — in .gitignore).
# Wird von deploy-onroda-production.sh gesourced, falls vorhanden.

# Git (Default: origin/main)
# GIT_REMOTE_BRANCH=origin/main

# PM2-Prozesse, nacheinander neu starten (Leerzeichen-getrennt).
# Standard: nur API (liefert gebaute Panels oft statisch mit aus).
# Separater Admin-Vite auf Port 3001: siehe Repo-Root ecosystem.config.cjs (onroda-admin-panel).
# ONRODA_PM2_APPS="onroda-api"
# ONRODA_PM2_APPS="onroda-api onroda-admin-panel"

# Nur nötig, wenn Nginx (oder anderer Host) die Vite-dist-Ordner nicht aus dem Repo liest,
# sondern aus /var/www/… — dann nach dem Build synchronisieren:
# ONRODA_RSYNC_ADMIN_DIST_TO=/var/www/admin-onroda/partners
# ONRODA_RSYNC_PARTNER_DIST_TO=/var/www/panel-onroda

# Optional: nach Deploy Nginx neu laden (Rechte für nginx -t + systemctl nötig)
# ONRODA_RELOAD_NGINX=1

# Nach jedem Deploy: scripts/verify-onroda-db-schema.sql gegen DATABASE_URL (012–014).
# Nur setzen, wenn der Deploy ohne Schema-Check durchlaufen muss (Notfall — riskant).
# ONRODA_SKIP_SCHEMA_VERIFY=1

# HTTP-Health-Checks am Ende des Deploys (curl, bricht bei Fehler ab).
# Default: eine URL http://127.0.0.1:<PORT>/api/healthz (<PORT> aus api-server/.env oder 3000).
# Zusätzlich z. B. Admin-Vite-Preview:
# ONRODA_HEALTHCHECK_URLS="http://127.0.0.1:3000/api/healthz http://127.0.0.1:3001/partners/"
# ONRODA_HEALTHCHECK_TIMEOUT=20
# ONRODA_SKIP_HEALTHCHECKS=1

# --seed-migration-tracker schreibt nur onroda_deploy_migrations, führt KEIN Migration-SQL aus.
# Ohne diese Bestätigung verweigert deploy-onroda-production.sh den Seed (verhindert Tracker≠Schema).
# ONRODA_CONFIRM_SEED_MIGRATION_TRACKER=1
