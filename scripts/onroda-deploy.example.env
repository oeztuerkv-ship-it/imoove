# Kopie nach scripts/onroda-deploy.env (nicht committen — in .gitignore).
# Wird von deploy-onroda-production.sh gesourced, falls vorhanden.

# Git (Default: origin/main)
# GIT_REMOTE_BRANCH=origin/main

# PM2-Prozesse, nacheinander neu starten (Leerzeichen-getrennt).
# Standard ist nur die API; die liefert unter Default-Pfaden auch die gebauten Panels aus.
# ONRODA_PM2_APPS="onroda-api"

# Nur nötig, wenn Nginx (oder anderer Host) die Vite-dist-Ordner nicht aus dem Repo liest,
# sondern aus /var/www/… — dann nach dem Build synchronisieren:
# ONRODA_RSYNC_ADMIN_DIST_TO=/var/www/admin-onroda/partners
# ONRODA_RSYNC_PARTNER_DIST_TO=/var/www/panel-onroda

# Optional: nach Deploy Nginx neu laden (Rechte für nginx -t + systemctl nötig)
# ONRODA_RELOAD_NGINX=1
